rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'steveewastaken@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Helpers ---
    function isValidArtist(data) {
      return (data.get('name', '') is string) && (data.get('name', '').size() > 0) &&
             (data.get('profilePictureUrl', '') is string);
    }

    function isValidAlbum(data) {
      return (data.get('title', '') is string) && (data.get('title', '').size() > 0) &&
             (data.get('coverImageUrl', '') is string) &&
             (data.get('artistId', '') is string) &&
             (data.get('similarAlbumIds', []) is list);
    }

    function isValidSong(data) {
      return (data.get('title', '') is string) && (data.get('title', '').size() > 0) &&
             (data.get('albumId', '') is string) &&
             (data.get('lyrics', '') is string) &&
             (data.get('unavailable', false) is bool) &&
             (data.get('trackNumber', 0) is int);
    }

    // --- Collections ---
    match /artists/{artistId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidArtist(request.resource.data);
      allow delete: if isAdmin();
    }

    match /albums/{albumId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidAlbum(request.resource.data);
      allow delete: if isAdmin();
    }

    match /songs/{songId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSong(request.resource.data);
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Admins must be added manually or via backend
    }
  }
}
